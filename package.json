{
  "name": "n8n-nodes-recurly",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Recurly subscription management providing 12 resources and 90+ operations for billing automation, subscription lifecycle management, and invoice processing.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-recurly.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-recurly#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-recurly/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "recurly",
    "subscription",
    "billing",
    "invoicing",
    "payments",
    "saas",
    "recurring-billing",
    "subscription-management"
  ],
  "main": "dist/nodes/Recurly/Recurly.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RecurlyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Recurly/Recurly.node.js",
      "dist/nodes/Recurly/RecurlyTrigger.node.js"
    ]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.27.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "xml2js": "^0.6.2"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
